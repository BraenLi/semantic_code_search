# QENAS Web Service 配置示例
# 复制此文件为 .env 并修改相应配置

# 服务配置
QENAS_HOST=0.0.0.0
QENAS_PORT=8000
QENAS_DEBUG=true

# API 配置
QENAS_API_PREFIX=/api/v1
QENAS_API_TITLE=QENAS API
QENAS_API_VERSION=0.1.0

# CORS 配置（逗号分隔）
QENAS_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# WebSocket 配置
QENAS_WS_ENDPOINT=/ws/qenas
QENAS_WS_PING_INTERVAL=30
QENAS_WS_PING_TIMEOUT=10

# 回测配置
QENAS_DEFAULT_INITIAL_CAPITAL=100000
QENAS_DEFAULT_COMMISSION_RATE=0.001
QENAS_DEFAULT_SLIPPAGE_RATE=0.001

# 日志配置
QENAS_LOG_LEVEL=INFO
